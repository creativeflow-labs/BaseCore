APP_ENV=local
APP_NAME=BaseCore v0.2
LOG_DIR=data/logs
ENABLE_AUTH=false
SERVICE_API_KEY=
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
STORE_RAW_OUTPUTS=false
DEFAULT_MODEL_SOURCE=internal
EXTERNAL_FALLBACK_ENABLED=true
REVIEWER_DEFAULT_SOURCE=external
LONG_INPUT_EXTERNAL_THRESHOLD=6000
MAX_ATTEMPTS=3
REQUEST_TIMEOUT_SECONDS=45
MAX_INPUT_CHARS=12000
MAX_CONTEXT_CHARS=24000

INTERNAL_BASE_URL=http://localhost:8000/v1
INTERNAL_API_KEY=EMPTY
INTERNAL_MODEL_NAME=basecore-internal
INTERNAL_PROVIDER=openai-compatible

EXTERNAL_PROVIDER=openai
EXTERNAL_BASE_URL=https://api.openai.com/v1
EXTERNAL_API_KEY=
EXTERNAL_MODEL_NAME=

VLLM_MODEL_ID=deepseek-ai/DeepSeek-R1-Distill-Qwen-7B
VLLM_SERVED_MODEL_NAME=basecore-internal
HF_TOKEN=
